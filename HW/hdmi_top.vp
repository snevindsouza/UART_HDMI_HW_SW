// Module : hdmi_top
// Author : Snevin Leoneel Dsouza
// Warning: This file is encrypted. Do not modify this file
// Recommended vivado versions: 2024.1 to 2029.1
`default_nettype none
module hdmi_top(
  input   wire        clk,
  input   wire        rst,
  input   wire  [1:0] pattern_sel,
  output  wire        hdmi_clk_n,
  output  wire        hdmi_clk_p,
  output  wire  [2:0] hdmi_tx_n,
  output  wire  [2:0] hdmi_tx_p
);
// VGA timing parameters
localparam  HVID = 1280;   // horizontal active video width pix clocks
localparam  HFP  = 110;    // horizontal front porch pix clocks
localparam  HS   = 40;     // horizontal hsync pulse width pix clocks
localparam  HBP  = 220;    // horizontal back porch pix clocks
localparam  VVID = 720;    // vertical active video lines
localparam  VFP  = 5;      // vertical front porch video lines
localparam  VS   = 5;      // vertical vsync pulse width video lines
localparam  VBP  = 20;     // vertical back porch video lines
// extra helping parameters
localparam  HC_MAX  = HVID+HFP+HS+HBP;  // one more than the max horizontal count value
localparam  VC_MAX  = VVID+VFP+VS+VBP;  // one more than the max vertical count value
localparam  HC_BITS = $clog2(HC_MAX);   // how many bits do we need to count this high?
localparam  VC_BITS = $clog2(VC_MAX);   // how many bits do we need to count this high?
wire                clk_74_25MHz, clk_371_25MHz;  // pixel clocks
wire                locked;
wire                hsync, vsync, vde; 
wire                vga_hsync, vga_vsync;
wire  [7:0]         red, green, blue;
wire  [HC_BITS-1:0] vga_col;
wire  [VC_BITS-1:0] vga_row;
//clock wizard configured with a 1x and 5x clock
clk_wiz_0 clk_wiz (
  .clk_out1 (clk_74_25MHz),   // 74.25MHz
  .clk_out2 (clk_371_25MHz),  // 371.25MHz
  .reset    (rst),
  .locked   (locked),
  .clk_in1  (clk)
);
//Real Digital VGA to HDMI converter
hdmi_tx_0 vga_to_hdmi (
  //Clocking and Reset
  .pix_clk        (clk_74_25MHz),
  .pix_clkx5      (clk_371_25MHz),
  .pix_clk_locked (locked),
  //Reset is active HIGH
  .rst            (rst),
  //Color and Sync Signals
  .red            (red),
  .green          (green),
  .blue           (blue),
  .hsync          (hsync),
  .vsync          (vsync),
  .vde            (vde),
  //aux Data (unused)
  .aux0_din       (4'b0),
  .aux1_din       (4'b0),
  .aux2_din       (4'b0),
  .ade            (1'b0),
  //Differential outputs
  .TMDS_CLK_P     (hdmi_clk_p),          
  .TMDS_CLK_N     (hdmi_clk_n),          
  .TMDS_DATA_P    (hdmi_tx_p),         
  .TMDS_DATA_N    (hdmi_tx_n)          
);
`pragma protect begin_protected
`pragma protect version=2
`pragma protect author="Snevin Leoneel Dsouza"
